# Copy to .env and adjust.

# Which corpus adapter to load (see api/corpora/). Options: markdown_dir | crystal_battle
CORPUS=crystal_battle

# For markdown_dir: the folder to ingest
CORPUS_PATH=./docs

# For crystal_battle: path to your local crystal-battle checkout
CRYSTAL_BATTLE_PATH=/home/wiz/Developer/grimoire/crystal-battle

# For pokeapi: a checkout of github.com/PokeAPI/pokeapi (only data/v2/csv is read).
# A sparse clone keeps it small:
#   git clone --depth 1 --filter=blob:none --sparse https://github.com/PokeAPI/pokeapi
#   cd pokeapi && git sparse-checkout set data/v2/csv
POKEAPI_PATH=/home/wiz/Developer/pokeapi

# Ollama (running on the host with your GPU)
OLLAMA_HOST=http://localhost:11434
EMBED_MODEL=nomic-embed-text
LLM_MODEL=gemma4:26b-a4b-it-q4_K_M

# Postgres (docker compose sets this for the api container automatically)
DATABASE_URL=postgresql://rag:rag@localhost:5432/rag

# Retrieval
CHUNK_SIZE=900
CHUNK_OVERLAP=150
TOP_K=8
# Below this top-1 similarity, answer "I don't know" instead of hallucinating.
# Tuned via the eval harness on the full two-corpus index: on-topic top-1 sims
# run 0.67-0.84, off-topic up to ~0.65. The margin narrows as the corpus grows.
MIN_SIMILARITY=0.66
